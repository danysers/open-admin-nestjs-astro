{
  "name": "open-admin-migration",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @openadmin/api dev",
    "dev:web": "pnpm --filter @openadmin/web dev",
    "build:shared": "pnpm --filter @openadmin/shared build",
    "build:api": "pnpm --filter @openadmin/api build",
    "build:web": "pnpm --filter @openadmin/web build",
    "build": "pnpm build:shared && pnpm build:api && pnpm build:web",
    "start:api": "pnpm --filter @openadmin/api start:prod",
    "start:web": "pnpm --filter @openadmin/web start"
  },
  "packageManager": "pnpm@10.33.0"
}
