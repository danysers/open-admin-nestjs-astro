---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - OpenAdmin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" />
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
      <div class="p-4 border-b border-gray-700">
        <span class="text-xl font-bold text-indigo-400">OpenAdmin</span>
      </div>
      <nav class="flex-1 overflow-y-auto p-2">
        <a href="/admin/dashboard" class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-sm">
          📊 Dashboard
        </a>
        <a href="/admin/users" class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-sm">
          👥 Users
        </a>
        <a href="/admin/roles" class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-sm">
          🔐 Roles
        </a>
        <a href="/admin/permissions" class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-sm">
          🛡 Permissions
        </a>
        <a href="/admin/menu" class="flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-700 text-sm">
          📋 Menu
        </a>
      </nav>
      <div class="p-4 border-t border-gray-700">
        <div id="user-info" class="text-sm text-gray-400 mb-2">Loading...</div>
        <button id="logout-btn" class="w-full bg-red-600 text-white py-1.5 rounded text-sm hover:bg-red-700">
          Logout
        </button>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <header class="bg-white shadow-sm h-14 flex items-center px-6">
        <span class="text-lg font-medium text-gray-700">{title}</span>
      </header>
      <main class="flex-1 overflow-y-auto p-6">
        <slot />
      </main>
    </div>
  </div>

  <script>
    function checkAuth() {
      const accessToken = localStorage.getItem('accessToken');
      const expiresAt = localStorage.getItem('expiresAt');
      
      if (!accessToken) {
        window.location.href = '/login';
        return false;
      }
      
      if (expiresAt && Date.now() > parseInt(expiresAt)) {
        const refreshToken = localStorage.getItem('refreshToken');
        if (refreshToken) {
          fetch('/api/auth/refresh', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refreshToken }),
          }).then(r => r.json()).then(data => {
            if (data.code === 200 && data.data?.accessToken) {
              localStorage.setItem('accessToken', data.data.accessToken);
              localStorage.setItem('refreshToken', data.data.refreshToken);
              localStorage.setItem('expiresAt', Date.now() + 3600000);
            } else {
              localStorage.clear();
              window.location.href = '/login';
            }
          }).catch(() => {
            localStorage.clear();
            window.location.href = '/login';
          });
        } else {
          localStorage.clear();
          window.location.href = '/login';
        }
      }
      return true;
    }

    checkAuth();

    const user = localStorage.getItem('user');
    if (user) {
      try {
        const userData = JSON.parse(user);
        document.getElementById('user-info').textContent = userData.username || 'Admin';
      } catch(e) {}
    }

    document.getElementById('logout-btn').addEventListener('click', () => {
      localStorage.clear();
      window.location.href = '/login';
    });
  </script>
</body>
</html>
